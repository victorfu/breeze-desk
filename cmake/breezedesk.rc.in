#include <windows.h>

@BREEZEDESK_WINDOWS_ICON_RESOURCE@

1 VERSIONINFO
FILEVERSION @PROJECT_VERSION_MAJOR@,@PROJECT_VERSION_MINOR@,@PROJECT_VERSION_PATCH@,0
PRODUCTVERSION @PROJECT_VERSION_MAJOR@,@PROJECT_VERSION_MINOR@,@PROJECT_VERSION_PATCH@,0
FILEFLAGSMASK 0x3fL
FILEOS VOS_NT_WINDOWS32
FILETYPE VFT_APP
BEGIN
  BLOCK "StringFileInfo"
  BEGIN
    BLOCK "040904b0"
    BEGIN
      VALUE "CompanyName", "@BREEZEDESK_ORGANIZATION_NAME@\0"
      VALUE "FileDescription", "Offline long-form transcription\0"
      VALUE "FileVersion", "@PROJECT_VERSION@\0"
      VALUE "InternalName", "@BREEZEDESK_RELEASE_EXECUTABLE_NAME@\0"
      VALUE "OriginalFilename", "@BREEZEDESK_RELEASE_EXECUTABLE_NAME@.exe\0"
      VALUE "ProductName", "@BREEZEDESK_PRODUCT_NAME@\0"
      VALUE "ProductVersion", "@PROJECT_VERSION@\0"
    END
  END
  BLOCK "VarFileInfo"
  BEGIN
    VALUE "Translation", 0x0409, 1200
  END
END
