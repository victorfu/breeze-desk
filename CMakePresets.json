{
  "version": 6,
  "cmakeMinimumRequired": { "major": 3, "minor": 24, "patch": 0 },
  "configurePresets": [
    {
      "name": "base",
      "hidden": true,
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build/${presetName}",
      "cacheVariables": {
        "CMAKE_EXPORT_COMPILE_COMMANDS": "ON",
        "CMAKE_UNITY_BUILD": "OFF",
        "BREEZEDESK_ENABLE_WHISPER": "ON",
        "BREEZEDESK_WINDOWS_BACKEND": "CPU",
        "BREEZEDESK_WARNINGS_AS_ERRORS": "ON"
      }
    },
    {
      "name": "debug",
      "inherits": "base",
      "cacheVariables": { "CMAKE_BUILD_TYPE": "Debug" }
    },
    {
      "name": "debug-runtime-off",
      "displayName": "Debug without whisper.cpp runtime",
      "description": "Protocol/domain development only; transcription is intentionally unavailable.",
      "inherits": "debug",
      "cacheVariables": { "BREEZEDESK_ENABLE_WHISPER": "OFF" }
    },
    {
      "name": "release",
      "inherits": "base",
      "cacheVariables": { "CMAKE_BUILD_TYPE": "Release", "BREEZEDESK_BUILD_TESTS": "OFF" }
    },
    {
      "name": "windows-universal",
      "inherits": "release",
      "cacheVariables": { "BREEZEDESK_WINDOWS_BACKEND": "VULKAN" }
    },
    {
      "name": "windows-cuda",
      "inherits": "release",
      "cacheVariables": { "BREEZEDESK_WINDOWS_BACKEND": "CUDA" }
    },
    {
      "name": "windows-cpu",
      "inherits": "release",
      "cacheVariables": { "BREEZEDESK_WINDOWS_BACKEND": "CPU" }
    }
  ],
  "buildPresets": [
    { "name": "debug", "configurePreset": "debug" },
    { "name": "debug-runtime-off", "configurePreset": "debug-runtime-off" },
    { "name": "release", "configurePreset": "release" },
    { "name": "windows-universal", "configurePreset": "windows-universal" },
    { "name": "windows-cuda", "configurePreset": "windows-cuda" },
    { "name": "windows-cpu", "configurePreset": "windows-cpu" }
  ],
  "testPresets": [
    { "name": "debug", "configurePreset": "debug", "output": { "outputOnFailure": true } },
    {
      "name": "debug-runtime-off",
      "configurePreset": "debug-runtime-off",
      "output": { "outputOnFailure": true }
    }
  ]
}
